     class="fixed inset-0 bg-black/40 hidden flex items-center justify-center">
    <div class="bg-white rounded-xl p-6 w-[300px] text-center shadow-lg">
        <h3 class="text-lg font-bold mb-2">Hostel Payment</h3>
        <p class="text-sm text-gray-600 mb-4">
            For Payments Details <b> Go Main Building</b>
        </p>
        <p class="text-sm text-gray-600 mb-4">
            Contact To Account Section Department <b> Ganesh Jha Sir</b>
        </p>
        <button id="PaymentClose"
                class="bg-primary text-white px-4 py-2 rounded-lg hover:bg-primary/90">
            OK
        </button>
    </div>
</div>

<!-- Modal For Maintenance Support -->
